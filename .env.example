# --- Cloud LLM (generation path) ---
# The Anthropic SDK reads ANTHROPIC_API_KEY directly from the environment.
ANTHROPIC_API_KEY=sk-ant-...

# --- DocsMind settings (env_prefix = DOCSMIND_) ---
# Generation model. Default is the most capable Opus tier; switch to
# claude-haiku-4-5 or claude-sonnet-4-6 for cheaper high-volume benchmarking.
DOCSMIND_CLOUD_LLM_MODEL=claude-opus-4-8

# Self-hosted embedding model (downloaded on first run; runs on CPU or GPU).
DOCSMIND_EMBED_MODEL=BAAI/bge-small-en-v1.5

# FAISS index type. Phase 1 supports "flat"; Phase 2 adds ivf/hnsw/pq.
DOCSMIND_INDEX_TYPE=flat

# Paths
DOCSMIND_DATA_DIR=data/sample_docs
DOCSMIND_INDEX_DIR=data/index

# Retrieval / chunking
DOCSMIND_TOP_K=4
DOCSMIND_CHUNK_SIZE=512
DOCSMIND_CHUNK_OVERLAP=64

# Generation
DOCSMIND_MAX_TOKENS=1024
